{
	"name": "back-end",
	"version": "1.0.0",
	"private": true,
	"description": "Minimal Express API for the vitesse-nuxt monorepo template.",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"server": "tsx watch -r dotenv/config src/server.ts",
		"server:once": "tsx -r dotenv/config src/server.ts",
		"start": "node dist/server.js",
		"build": "tsc -p tsconfig.json",
		"watch": "tsc -w",
		"dev": "tsx watch -r dotenv/config src/server.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"up": "taze major -I",
		"lint": "eslint \"src/**/*.{js,ts}\"",
		"lint-fix": "eslint \"src/**/*.{js,ts}\" --fix"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"cors": "^2.8.5",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"helmet": "^8.1.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.6.0",
		"globals": "^17.4.0",
		"tsx": "^4.21.0",
		"typescript-eslint": "^8.59.0"
	}
}
