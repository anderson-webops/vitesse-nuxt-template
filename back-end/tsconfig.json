{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"incremental": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"sourceMap": true,
		"outDir": "./dist",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules"
	]
}
